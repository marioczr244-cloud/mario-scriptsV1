-- ==================== FUNÇÕES PRINCIPAIS ====================

-- Função para teleportar
local function teleportTo(position)
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.CFrame = position
    end
end

-- Função para ativar aura
local function activateAura()
    if autoAura then
        local args = {[1] = "Aura", [2] = "Activate"}
        replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
    end
end

-- Função para pegar missão
local function getQuest(questNPC)
    local args = {[1] = "StartQuest", [2] = questNPC}
    replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
end

-- Função para entregar missão
local function completeQuest()
    local args = {[1] = "FinishQuest"}
    replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
end

-- Função para distribuir stats
local function distributeStats()
    if autoStats then
        for stat, priority in pairs(statPriority) do
            for i = 1, priority do
                local args = {[1] = "AddPoint", [2] = stat, [3] = 1}
                replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
            end
        end
    end
end

-- Função para juntar mobs (Bring Mob)
local function bringMobsToPosition(mobPosition)
    if bringMob then
        for _, mob in ipairs(workspace:GetDescendants()) do
            if mob:IsA("Model") and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                if (mob.HumanoidRootPart.Position - mobPosition).Magnitude < 100 then
                    mob.HumanoidRootPart.CFrame = mobPosition
                end
            end
        end
    end
end

-- Função para farmar NPCs
local function farmNPCs(npcName, questArea)
    if not autoFarm then return end
    
    for _, npc in ipairs(workspace:GetDescendants()) do
        if npc:IsA("Model") and npc.Name == npcName and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
            activateAura()
            local npcPos = npc.HumanoidRootPart.Position
            bringMobsToPosition(npcPos)
            teleportTo(npc.HumanoidRootPart.CFrame * CFrame.new(0, 5, 5))
            
            -- Atacar NPC
            local args = {[1] = "Click"}
            replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
        end
    end
end

-- Função para comprar frutas
local function buyFruit()
    if autoFruit then
        local args = {[1] = "PurchaseFruit", [2] = "Random"}
        replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
    end
end

-- Função para detectar frutas no chão (Fruit Sniper)
local function detectFruits()
    if not fruitSniper then return end
    
    local rareFruits = {"Leopard", "Dragon", "Venom", "Dough", "Spirit", "Control"}
    for _, fruit in ipairs(workspace:GetDescendants()) do
        if fruit:IsA("Tool") and fruit:FindFirstChild("Handle") then
            for _, rare in ipairs(rareFruits) do
                if fruit.Name:find(rare) then
                    teleportTo(fruit.Handle.CFrame)
                    Rayfield:Notify({
                        Title = "Fruit Sniper",
                        Content = "Fruta rara encontrada: " .. fruit.Name,
                        Duration = 3
                    })
                end
            end
        end
    end
end

-- Função para farmar bosses
local function farmBoss(bossName)
    if not autoBoss then return end
    
    for _, boss in ipairs(workspace:GetDescendants()) do
        if boss:IsA("Model") and boss.Name == bossName and boss:FindFirstChild("Humanoid") and boss.Humanoid.Health > 0 then
            teleportTo(boss.HumanoidRootPart.CFrame * CFrame.new(0, 5, 5))
            activateAura()
            
            local args = {[1] = "Click"}
            replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
        end
    end
end

-- Função para raids
local function startRaid()
    if not autoDungeon then return end
    
    local args = {[1] = "Raids", [2] = "Start"}
    replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
end

-- Função para acelerar barco (Fast Boat)
local function boostBoat()
    if not fastBoat then return end
    
    for _, boat in ipairs(workspace:GetDescendants()) do
        if boat:IsA("VehicleSeat") and boat.Parent and boat.Parent:FindFirstChild("BodyVelocity") then
            boat.Parent.BodyVelocity.Velocity = boat.Parent.BodyVelocity.Velocity * 10
        end
    end
end

-- Função para comprar itens (Auto Buy)
local function buyItem(itemName)
    if not autoBuy then return end
    
    local args = {[1] = "BuyItem", [2] = itemName}
    replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
end

-- Função para Auto Saber/CDK
local function doSaberQuest()
    if not autoSaber then return end
    
    -- Teleport para a ilha do Saber
    teleportTo(CFrame.new(-1195, 85, -1080))
    wait(2)
    
    -- Completar missão do Saber
    local args = {[1] = "Saber", [2] = "Complete"}
    replicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
end

-- Função para Server Hop
local function hopServer()
    if not serverHop then return end
    
    local servers = game:GetService("TeleportService"):GetGameInstances()
    for _, server in ipairs(servers) do
        if server.Ping < 100 then
            teleportService:TeleportToPlaceInstance(game.PlaceId, server.JobId, player)
            break
        end
    end
end

-- Função para FPS Boost
local function boostFPS()
    if not fpsBoost then return end
    
    for _, descendant in ipairs(workspace:GetDescendants()) do
        if descendant:IsA("Decal") or descendant:IsA("Texture") then
            descendant.Transparency = 1
        end
        if descendant:IsA("ParticleEmitter") then
            descendant.Enabled = false
        end
    end
    
    game:GetService("Lighting").GlobalShadows = false
    game:GetService("Lighting").Technology = Enum.Technology.Compatibility
end

